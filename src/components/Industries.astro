const catList = document.getElementById("catList");
const productPanel = document.getElementById("productPanel");

Object.keys(data).forEach(cat => {
  const d = data[cat];
  const item = document.createElement("div");
  item.className = "cat-item";
  item.innerHTML = `
    <div class="cat-icon">${d.icon}</div>
    <span class="cat-name">${cat}</span>
    <span class="cat-count">${d.products.length || "—"}</span>
  `;
  item.addEventListener("click", () => {
    document.querySelectorAll(".cat-item").forEach(i => i.classList.remove("active"));
    item.classList.add("active");
    renderProducts(cat);
  });
  catList.appendChild(item);
});

function renderProducts(cat) {
  const d = data[cat];
  const tags = ["Tümü", ...new Set(d.products.map(p => p.tag))];

  function renderGrid(filter) {
    const filtered = filter === "Tümü" ? d.products : d.products.filter(p => p.tag === filter);
    return filtered.map(p => `
      <div class="product-card">
        ${p.img
          ? `<img class="product-img" src="${p.img}" alt="${p.name}" loading="lazy" />`
          : `<div class="product-img" style="display:flex;align-items:center;justify-content:center;font-size:2.5rem;">${d.icon}</div>`
        }
        <div class="product-body">
          <span class="product-tag">${p.tag}</span>
          <div class="product-name">${p.name}</div>
          <a href="#iletisim" class="product-btn">Teklif Al <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>
    `).join("");
  }

  productPanel.innerHTML = `
    <div class="panel-header">
      <div class="panel-icon">${d.icon}</div>
      <div>
        <div class="panel-title">${cat}</div>
        <div class="panel-desc">${d.desc}</div>
        <div class="panel-meta">${d.products.length} ürün</div>
      </div>
    </div>
    <div class="filter-tabs" id="filterTabs">
      ${tags.map(t => `<button class="filter-tab ${t==="Tümü"?"active":""}" data-tag="${t}">${t}</button>`).join("")}
    </div>
    <div class="products-grid" id="productsGrid">
      ${renderGrid("Tümü")}
    </div>
  `;

  document.querySelectorAll(".filter-tab").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".filter-tab").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      document.getElementById("productsGrid").innerHTML = renderGrid(btn.dataset.tag);
    });
  });

  productPanel.style.animation = "none";
  productPanel.offsetHeight;
  productPanel.style.animation = "fadeSlide .3s ease";
}
