---

<section class="section industries-section" id="sektorler">
  <div class="container">
    <div class="section-label">Hizmet Verdiğimiz Sektörler</div>
    <h2 class="section-title">Endüstriye Göre<br/><em>Ürün Bulun</em></h2>
    <p class="section-sub">Sektörünüzü seçin, size özel ürün portföyünü görüntüleyin.</p>
    <div class="industries-layout">
      <div class="cat-list" id="catList"></div>
      <div class="product-panel" id="productPanel">
        <div class="panel-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <p>Bir sektör seçerek<br/>ürünleri görüntüleyin</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .industries-section { background: #f8f8f8; padding: 6rem 0; }
  .section-label { font-size:.7rem; font-weight:600; letter-spacing:.2em; text-transform:uppercase; color:var(--red); margin-bottom:1rem; display:flex; align-items:center; gap:.75rem; }
  .section-label::before { content:""; display:inline-block; width:24px; height:2px; background:var(--red); }
  .section-title { font-family:"DM Serif Display",serif; font-size:clamp(1.8rem,4vw,2.5rem); font-weight:400; line-height:1.15; margin-bottom:.75rem; }
  .section-title em { font-style:italic; color:var(--red); }
  .section-sub { font-size:1rem; color:#7a7a7a; margin-bottom:3rem; max-width:500px; }
  .industries-layout { display:grid; grid-template-columns:280px 1fr; gap:2rem; align-items:start; }
  .cat-list { display:flex; flex-direction:column; gap:.4rem; }
  .cat-item { display:flex; align-items:center; gap:.85rem; padding:.8rem 1rem; border-radius:12px; cursor:pointer; transition:all 0.25s cubic-bezier(0.4,0,0.2,1); border:1.5px solid transparent; background:white; }
  .cat-item:hover { border-color:#e8e8e8; box-shadow:0 4px 20px rgba(0,0,0,0.08); transform:translateX(3px); }
  .cat-item.active { background:var(--red); border-color:var(--red); transform:translateX(6px); box-shadow:0 8px 24px rgba(200,16,46,.25); }
  .cat-icon { width:40px; height:40px; border-radius:9px; background:#f4f4f4; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; }
  .cat-item.active .cat-icon { background:rgba(255,255,255,.15); }
  .cat-name { font-size:.875rem; font-weight:600; color:#0D0D0D; transition:color 0.25s; }
  .cat-item.active .cat-name { color:white; }
  .cat-count { margin-left:auto; font-size:.65rem; font-weight:700; color:#7a7a7a; background:#f4f4f4; padding:2px 7px; border-radius:100px; transition:all 0.25s; flex-shrink:0; }
  .cat-item.active .cat-count { background:rgba(255,255,255,.2); color:white; }
  .product-panel { background:white; border-radius:16px; padding:1.75rem; box-shadow:0 4px 20px rgba(0,0,0,0.08); min-height:400px; animation:fadeSlide .3s ease; }
  @keyframes fadeSlide { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .panel-header { display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; padding-bottom:1.25rem; border-bottom:1px solid #e8e8e8; }
  .panel-icon { width:48px; height:48px; border-radius:10px; background:rgba(200,16,46,.08); display:flex; align-items:center; justify-content:center; font-size:1.5rem; flex-shrink:0; }
  .panel-title { font-family:"DM Serif Display",serif; font-size:1.4rem; font-weight:400; }
  .panel-desc { font-size:.82rem; color:#7a7a7a; margin-top:2px; }
  .panel-meta { font-size:.75rem; color:var(--red); font-weight:600; margin-top:3px; }
  .filter-tabs { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1.25rem; }
  .filter-tab { font-size:.72rem; font-weight:600; padding:.35rem .85rem; border-radius:100px; border:1.5px solid #e8e8e8; background:white; cursor:pointer; transition:all 0.25s; color:#3d3d3d; }
  .filter-tab:hover { border-color:var(--red); color:var(--red); }
  .filter-tab.active { background:var(--red); border-color:var(--red); color:white; }
  .products-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:1rem; }
  .product-card { border:1.5px solid #e8e8e8; border-radius:12px; overflow:hidden; transition:all 0.25s; }
  .product-card:hover { border-color:rgba(200,16,46,.25); box-shadow:0 8px 24px rgba(0,0,0,.09); transform:translateY(-3px); }
  .product-img { width:100%; height:130px; object-fit:contain; background:#fafafa; padding:12px; display:block; }
  .product-body { padding:1rem; }
  .product-tag { font-size:.62rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--red); background:rgba(200,16,46,.07); padding:2px 7px; border-radius:100px; display:inline-block; margin-bottom:.6rem; }
  .product-name { font-size:.85rem; font-weight:600; color:#0D0D0D; line-height:1.3; margin-bottom:.75rem; }
  .product-btn { display:inline-flex; align-items:center; gap:.4rem; font-size:.75rem; font-weight:600; color:var(--red); transition:gap 0.25s; text-decoration:none; }
  .product-btn:hover { gap:.65rem; }
  .panel-placeholder { display:flex; flex-direction:column; align-items:center; justify-content:center; height:320px; color:#7a7a7a; text-align:center; gap:1rem; }
  .panel-placeholder svg { opacity:.15; }
  @media (max-width:768px) {
    .industries-layout { grid-template-columns:1fr; }
    .cat-list { flex-direction:row; flex-wrap:wrap; }
    .cat-item { flex:1; min-width:130px; transform:none !important; }
    .cat-count { display:none; }
  }
</style>

