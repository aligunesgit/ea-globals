---
---
<section class="cta-section" id="neden-biz">
  <div class="cta-section__bg">
    <div class="cta-grid"></div>
  </div>
  <div class="container cta-section__inner">
    <div class="cta-section__content">
      <div class="section-label" style="color: rgba(255,255,255,0.5);">
        <span style="background:rgba(255,255,255,0.3)"></span>
        Neden EA Globals?
      </div>
      <h2 class="cta-section__title">
        Üretimde Verimlilik,<br />
        <em>Tedarikde Rahatlık</em>
      </h2>
      <p class="cta-section__desc">
        Doğru yağı, doğru zamanda, doğru fiyatla almak artık çok daha kolay. Tek noktadan tüm endüstriyel kimyasal ihtiyaçlarınızı karşılıyoruz.
      </p>
      <div class="cta-section__actions">
        <a href="#teklif" class="btn btn-primary">Hemen Teklif Al</a>
        <a href="tel:+90XXXXXXXXXX" class="btn btn-outline-white">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.23h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.79a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Bizi Arayın
        </a>
      </div>
    </div>

    <div class="cta-section__stats">
      <div class="cta-stat">
        <div class="cta-stat__icon">📦</div>
        <div class="cta-stat__num">500+</div>
        <div class="cta-stat__label">Ürün Çeşidi</div>
      </div>
      <div class="cta-stat">
        <div class="cta-stat__icon">🌍</div>
        <div class="cta-stat__num">50+</div>
        <div class="cta-stat__label">Ülkeye İhracat</div>
      </div>
      <div class="cta-stat">
        <div class="cta-stat__icon">⚡</div>
        <div class="cta-stat__num">Hızlı</div>
        <div class="cta-stat__label">Teslimat</div>
      </div>
      <div class="cta-stat">
        <div class="cta-stat__icon">🔬</div>
        <div class="cta-stat__num">Teknik</div>
        <div class="cta-stat__label">Danışmanlık</div>
      </div>
    </div>
  </div>
</section>

<style>
.cta-section {
  background: var(--black);
  position: relative;
  overflow: hidden;
  padding: 6rem 0;
}
.cta-section__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.cta-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(200,16,46,0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,16,46,0.08) 1px, transparent 1px);
  background-size: 50px 50px;
}
.cta-section__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
  position: relative;
  z-index: 1;
}
.cta-section__title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400;
  color: var(--white);
  line-height: 1.1;
  margin-bottom: 1.25rem;
}
.cta-section__title em {
  font-style: italic;
  color: var(--red);
}
.cta-section__desc {
  font-size: 1rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.75;
  margin-bottom: 2rem;
}
.cta-section__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

.cta-section__stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.cta-stat {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  text-align: center;
  transition: all var(--transition);
}
.cta-stat:hover {
  background: rgba(200,16,46,0.1);
  border-color: rgba(200,16,46,0.3);
}
.cta-stat__icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
.cta-stat__num {
  font-family: var(--font-display);
  font-size: 1.5rem;
  color: var(--white);
  line-height: 1;
  margin-bottom: 0.25rem;
}
.cta-stat__label {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.4);
  font-weight: 500;
}

@media (max-width: 900px) {
  .cta-section__inner { grid-template-columns: 1fr; gap: 3rem; }
}
</style>
